{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": false,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react",
    "baseUrl": "./src/",
    "paths": {
      "@Types":[
        "Types/types"
      ],
      "@Sections/*":[
        "Sections/Navbar/*",
        "Sections/Namer/*",
        "Sections/About/*",
        "Sections/Skills/*",
        "Sections/Projects/*",
        "Sections/Contact/*"
      ],
      "@Hooks/*":[
        "Hooks/*"
      ],
      "@Components/*":[
        "Components/StackSvg/*",
        "Components/JButton/*"
      ]
    }
  },
  "include": ["./src"]
}
